//@version=6
strategy("5m ORB First Retest Respect Only (NY Time)", overlay=true, initial_capital=100000, pyramiding=0, process_orders_on_close=true)

showLines  = input.bool(true, "Show range high/low")
rrMultiple = input.float(2.0, "Take Profit (R)", minval=0.1, step=0.1)

nyTZ = "America/New_York"
is5m = timeframe.isminutes and timeframe.multiplier == 5

// ===== 纽约时间 =====
nyHour     = hour(time, nyTZ)
nyMinute   = minute(time, nyTZ)
nyTotalMin = nyHour * 60 + nyMinute

// 9:30–10:30，包含10:30
inRangeSession = nyTotalMin >= 570 and nyTotalMin <= 630
// 10:35–12:00
inTradeSession = nyTotalMin > 630 and nyTotalMin < 720
afterNoon      = nyTotalMin >= 720

// ===== 纽约日期 =====
nyYear  = year(time, nyTZ)
nyMonth = month(time, nyTZ)
nyDay   = dayofmonth(time, nyTZ)
nyDate  = nyYear * 10000 + nyMonth * 100 + nyDay
newDay  = ta.change(nyDate) != 0

// ===== 变量 =====
var float rangeHigh = na
var float rangeLow  = na
var bool  rangeReady = false

var bool breakoutSeen = false
var int  breakoutDir = 0              // 1 = long, -1 = short
var float breakoutStop = na
var int breakoutBarIndex = na

var bool retestDone = false           // 是否已经发生过第一次回踩
var bool setupInvalid = false         // setup 是否作废
var bool tradeTakenToday = false

// ===== 每日重置 =====
if newDay
    rangeHigh := na
    rangeLow := na
    rangeReady := false

    breakoutSeen := false
    breakoutDir := 0
    breakoutStop := na
    breakoutBarIndex := na

    retestDone := false
    setupInvalid := false
    tradeTakenToday := false

// ===== 统计区间 =====
if is5m and inRangeSession
    rangeHigh := na(rangeHigh) ? high : math.max(rangeHigh, high)
    rangeLow  := na(rangeLow)  ? low  : math.min(rangeLow, low)

// ===== 区间完成 =====
if is5m and not inRangeSession and not na(rangeHigh) and not na(rangeLow)
    rangeReady := true

// ===== 突破 =====
longBreak  = is5m and rangeReady and inTradeSession and not breakoutSeen and not tradeTakenToday and close > rangeHigh
shortBreak = is5m and rangeReady and inTradeSession and not breakoutSeen and not tradeTakenToday and close < rangeLow

if longBreak
    breakoutSeen := true
    breakoutDir := 1
    breakoutStop := low
    breakoutBarIndex := bar_index
    retestDone := false
    setupInvalid := false

if shortBreak
    breakoutSeen := true
    breakoutDir := -1
    breakoutStop := high
    breakoutBarIndex := bar_index
    retestDone := false
    setupInvalid := false

// ===== 第一次回踩判定 =====
// 多头：后续某根bar第一次碰到 rangeHigh
longRetest = is5m and inTradeSession and breakoutSeen and breakoutDir == 1 and not retestDone and not setupInvalid and not tradeTakenToday and bar_index > breakoutBarIndex and low <= rangeHigh

// 空头：后续某根bar第一次碰到 rangeLow
shortRetest = is5m and inTradeSession and breakoutSeen and breakoutDir == -1 and not retestDone and not setupInvalid and not tradeTakenToday and bar_index > breakoutBarIndex and high >= rangeLow

// ===== 第一次回踩：要么respect开单，要么失败作废 =====
if longRetest
    retestDone := true
    if close > rangeHigh
        entryPrice = close
        stopPrice  = breakoutStop
        risk = entryPrice - stopPrice
        if risk > 0
            tpPrice = entryPrice + risk * rrMultiple
            strategy.entry("Long", strategy.long)
            strategy.exit("Long Exit", from_entry="Long", stop=stopPrice, limit=tpPrice)
            tradeTakenToday := true
        else
            setupInvalid := true
    else
        setupInvalid := true

if shortRetest
    retestDone := true
    if close < rangeLow
        entryPrice = close
        stopPrice  = breakoutStop
        risk = stopPrice - entryPrice
        if risk > 0
            tpPrice = entryPrice - risk * rrMultiple
            strategy.entry("Short", strategy.short)
            strategy.exit("Short Exit", from_entry="Short", stop=stopPrice, limit=tpPrice)
            tradeTakenToday := true
        else
            setupInvalid := true
    else
        setupInvalid := true

// ===== 中午后不再等待 =====
if afterNoon and strategy.position_size == 0 and not tradeTakenToday
    breakoutSeen := false
    breakoutDir := 0
    breakoutStop := na
    breakoutBarIndex := na
    retestDone := false
    setupInvalid := false

// ===== 绘图 =====
plot(showLines and rangeReady ? rangeHigh : na, "Range High", color=color.green, linewidth=2, style=plot.style_linebr)
plot(showLines and rangeReady ? rangeLow  : na, "Range Low",  color=color.red, linewidth=2, style=plot.style_linebr)

plotshape(longBreak,  title="Long Break",  style=shape.triangleup,   location=location.belowbar, color=color.green,  size=size.tiny, text="LB")
plotshape(shortBreak, title="Short Break", style=shape.triangledown, location=location.abovebar, color=color.red,    size=size.tiny, text="SB")

plotshape(longRetest,  title="Long First Retest",  style=shape.circle, location=location.belowbar, color=color.lime,   size=size.tiny, text="LR")
plotshape(shortRetest, title="Short First Retest", style=shape.circle, location=location.abovebar, color=color.orange, size=size.tiny, text="SR")
